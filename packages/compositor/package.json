{
  "name": "@officium-novum/compositor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "compare:phase-3-perl": "pnpm -C ../parser build && pnpm -C ../rubrical-engine build && pnpm build && node ./test/fixtures/compare-phase-3-perl.mjs",
    "compare:phase-3-perl:full": "pnpm compare:phase-3-perl -- --date __full-year__",
    "test": "vitest run",
    "test:no-throw": "vitest run -- test/integration/no-throw-sweep.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@officium-novum/parser": "workspace:*",
    "@officium-novum/rubrical-engine": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
