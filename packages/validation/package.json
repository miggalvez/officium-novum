{
  "name": "@officium-novum/validation",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run && pnpm run audit:citations && pnpm run audit:reviewer-privacy && pnpm run audit:reviewer-reports && pnpm run report:multi-year",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "audit:citations": "node --import tsx src/audit-citations.ts",
    "audit:reviewer-privacy": "node --import tsx src/audit-reviewer-privacy.ts",
    "audit:reviewer-reports": "node --import tsx src/audit-reviewer-reports.ts",
    "report:multi-year": "node --import tsx src/report-multi-year.ts"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
