      "samples": {
        "Ant Vespera": [
          "Hoc est præcéptum meum, * ut diligátis ínvicem, sicut diléxi vos.",
          "Majórem caritátem * nemo habet, ut ánimam suam ponat quis pro amícis suis.",
        ],
        "Lectio1": [
          "De Epístola prima beáti Pauli Apóstoli ad Corínthios",
          "!1 Cor 4:1-4",
        ],
        "Officium": [
          "Commune Apostolorum",
        ],
        "Oratio": [
          "!Oratio propria.",
        ],
        "Rank": [],
        "Responsory1": [
          "R. Ecce ego mitto vos sicut oves in médio lupórum, dicit Dóminus:",
          "* Estóte ergo prudéntes sicut serpéntes, et símplices sicut colúmbæ.",
        ],
        "Rule": [
          "Psalmi Dominica",
          "Antiphonas horas",
        ],
